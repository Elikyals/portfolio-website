---
interface Props {
    title: string
    description?: string
}

const { title, description = "Network & Infrastructure Engineer - Eliyahu K. Yalley"} = Astro.props
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <meta name="description" content={description} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{title}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

        <meta property="og:title" content="Eliyahu Kainyah Yalley" />
        <meta property="og:description" content={description} />
        <meta property="og:url" content="https://eliyahukyalley.dev" />
        <meta property="og:type" content="website" />

        <script type="application/ld+json">
            {
            "@context": "https://schema.org",
            "@type": "Person",
            "name": "Eliyahu Kainyah Yalley",
            "url": "https://eliyahukyalley.dev",
            "jobTitle": "Network & Infrastructure Engineer",
            "alumniOf": {
                "@type": "CollegeOrUniversity",
                "name": "University of Maryland, College Park"
            },
            "sameAs": [
                "https://linkedin.com/in/eliyahukyalley",
                "https://github.com/Elikyals",
                "https://instagram.com/elikyals",
                "https://app.joinhandshake.com/profiles/eliyahukyalley"
            ]
        }
        </script>
    </head>
    <body>
        <slot />
    </body>
</html>

<style is:global>
    @import "../styles/global.css";
</style>