---
import BaseLayout from '../layouts/BaseLayout.astro'
import NavBar from '../components/NavBar.astro'

interface Props {
    title: string
    date: string
    coverImage?: string
}

const { title, date, coverImage } = Astro.props
---

<BaseLayout title={`${title} — Eliyahu K. Yalley`}>
    <NavBar />
    <article class="blog-post">
        <div class="blog-post-container">
            <a href="/#blog" class="back-link">← Blog</a>

            {coverImage && (
                <img src={coverImage} alt={title} class="cover-image" />
            )}

            <h1 class="post-title">{title}</h1>
            <p class="post-date">{date}</p>
            <hr class="divider" />

            <div class="post-content">
                <slot />
            </div>
        </div>
    </article>
</BaseLayout>

<style>
    .blog-post {
        padding: 80px 120px;
    }

    .blog-post-container {
        max-width: 740px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .back-link {
        font-family: var(--font-body);
        font-size: 14px;
        color: var(--accent);
        text-decoration: none;
        margin-bottom: 24px;
        display: inline-block;
        transition: opacity 0.2s ease;
    }

    .back-link:hover {
        opacity: 0.75;
    }

    .cover-image {
        width: 100%;
        height: 360px;
        object-fit: cover;
        border-radius: 8px;
        margin-bottom: 32px;
    }

    .post-title {
        font-family: var(--font-display);
        font-size: 40px;
        font-weight: 700;
        color: var(--text-primary);
        line-height: 1.2;
        margin-bottom: 12px;
    }

    .post-date {
        font-family: var(--font-body);
        font-size: 13px;
        color: var(--text-secondary);
        margin-bottom: 16px;
    }

    .divider {
        border: none;
        border-top: 1px solid var(--border);
        margin-bottom: 24px;
    }

    .post-content {
        font-family: var(--font-body);
        font-size: 16px;
        color: var(--text-primary);
        line-height: 1.7;
    }
    .post-content p {
        margin-bottom: 24px;
    }

    .post-content h2 {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 700;
        color: var(--text-primary);
        margin: 40px 0 16px;
    }

    .post-content h3 {
        font-family: var(--font-display);
        font-size: 20px;
        font-weight: 500;
        color: var(--text-primary);
        margin: 32px 0 12px;
    }

    .post-content a {
        color: var(--accent);
        text-decoration: underline;
    }

    .post-content code {
        font-family: var(--font-mono, monospace);
        font-size: 14px;
        background: var(--bg-surface);
        padding: 2px 6px;
        border-radius: 4px;
        color: var(--accent);
    }

    .post-content pre {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 24px;
        overflow-x: auto;
        margin-bottom: 24px;
    }

    .post-content pre code {
        background: none;
        padding: 0;
        font-size: 14px;
        color: var(--text-primary);
    }

    /* Mobile */
    @media (max-width: 768px) {
        .blog-post {
        padding: 80px 24px;
        }

        .post-title {
        font-size: 28px;
        }

        .cover-image {
        height: 200px;
        }
    }
</style>